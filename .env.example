# Environment Configuration

# Discord Bot Token (Required)
# Get this from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Bot Application ID (Required for slash commands)
# Found in Discord Developer Portal
CLIENT_ID=your_client_id_here

# Guild ID for testing (Optional - for guild-specific slash commands)
GUILD_ID=your_test_guild_id_here

# Welcome Channel ID (Optional - defaults to system channel or first text channel)
WELCOME_CHANNEL_ID=

# Custom Welcome Message (Optional - uses default if not set)
# Use {user} for the new member's mention, {server} for server name, {count} for member count
WELCOME_MESSAGE=🎉 Welcome {user} to **{server}**! You are our {count}th member! Enjoy your stay! 🚀

# Enable DM Welcome (Optional - set to "true" to send DM to new members)
ENABLE_DM_WELCOME=false

# DM Welcome Message (Optional)
DM_WELCOME_MESSAGE=Welcome to {server}! Check out our rules and have fun!

# Auto-Role on Join (Premium Feature)
# Comma-separated list of role IDs to assign to new members
AUTO_ROLES=

# Log Level (debug, info, warn, error)
LOG_LEVEL=info
