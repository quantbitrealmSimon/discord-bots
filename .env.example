# Discord Bot Token (required)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (required for slash commands)
# Found in General Information tab of your app
DISCORD_CLIENT_ID=your_client_id_here

# AI Provider API Key (choose one)
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# OR Kimi (Moonshot)
KIMI_API_KEY=your_kimi_api_key_here

# AI Model Configuration
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
# For Kimi: AI_MODEL=kimi-k2.5

# Bot Configuration
BOT_NAME=QuantZen AI
DEFAULT_PERSONALITY=You are a helpful, friendly AI assistant. Be concise but informative.
MAX_CONTEXT_MESSAGES=10
RATE_LIMIT_PER_MINUTE=20

# Premium Features (optional)
PREMIUM_ROLE_ID=
ENABLE_IMAGE_GENERATION=false

# Logging
LOG_LEVEL=info
NODE_ENV=production
